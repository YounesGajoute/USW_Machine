# ── SQLite API server ────────────────────────────────────────────────────────
# Port the Express API listens on (default: 3333)
PORT=3333

# Session signing secret — change in production
SESSION_SECRET=app-dev-change-me-in-production

# Override SQLite DB file path (default: data/maindata.db)
# MAIN_DATA_DB_PATH=/absolute/or/relative/path/to/maindata.db

# ── EtherCAT (Lifter / I/O via pysoem) ────────────────────────────────────────
# When "1" / true: spawn ethercat_bridge.py after the API listens (same as POST /api/lifter/connect).
# ./start.sh defaults this to 1. Set 0 to run the API without the bridge (e.g. dev with no hardware).
# ETHERCAT_AUTO_CONNECT=1
# Linux interface for pysoem (default in ethercat.config.json is eth1 = Realtek RTL8152 USB on this Pi).
# ETHERCAT_INTERFACE=eth1

# ── Vision Pi proxy ───────────────────────────────────────────────────────────
# Base URL of the Vision inspection slave (default: http://192.168.10.2:5000)
VISION_URL=http://192.168.10.2:5000

# Optional shared secret forwarded as X-Vision-Remote-Key to the Vision Pi
# VISION_REMOTE_KEY=your-secret-key

# ── Reference broadcast (USB serial, e.g. FTDI FT232) ─────────────────────────
# After a valid scan/select, the API sends the canonical DB name to both paths.
# REFERENCE_SERIAL_WELD_PATH=/dev/ttyUSB0
# REFERENCE_SERIAL_SHRINK_PATH=/dev/ttyUSB1
# Shared defaults (used when per-port vars below are unset):
# REFERENCE_SERIAL_BAUD=9600
# REFERENCE_SERIAL_LINE_ENDING=CRLF
# Optional per machine (override shared baud / line ending for that port only):
# REFERENCE_SERIAL_WELD_BAUD=9600
# REFERENCE_SERIAL_SHRINK_BAUD=9600
# REFERENCE_SERIAL_WELD_LINE_ENDING=CRLF
# REFERENCE_SERIAL_SHRINK_LINE_ENDING=CRLF
