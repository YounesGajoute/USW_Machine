# ── SQLite API server ────────────────────────────────────────────────────────
# Port the Express API listens on (default: 3333)
PORT=3333

# Session signing secret — change in production
SESSION_SECRET=app-dev-change-me-in-production

# Override SQLite DB file path (default: data/maindata.db)
# MAIN_DATA_DB_PATH=/absolute/or/relative/path/to/maindata.db

# ── EtherCAT (Lifter / I/O via pysoem) ────────────────────────────────────────
# Default: bridge starts when the API listens (same as ./start.sh and boot stack). Unset = on.
# Set 0 / false / no / off to run the API without the bridge (e.g. dev with no hardware).
# ETHERCAT_AUTO_CONNECT=0
# Linux interface for pysoem (default in ethercat.config.json is eth1 = Realtek RTL8152 USB on this Pi).
# ETHERCAT_INTERFACE=eth1
# Skip DI0 panel button check during initialization (bench / dev only).
# ETHERCAT_SKIP_INIT_BUTTON=1

# Skip DI1 panel Start button check for production sequence (HMI-only start).
# ETHERCAT_SKIP_START_BUTTON=1

# Disable server-side DI0/DI1 rising-edge monitor (use frontend polling or API only).
# ETHERCAT_DISABLE_PANEL_BUTTONS=1

# Production sequence delays (ms) and pick position (mm)
# PRODUCTION_DELAY_CLAMP_MS=500
# PRODUCTION_DELAY_LEVER_UP_MS=500
# PRODUCTION_DELAY_LEVER_DOWN_MS=500
# PRODUCTION_DELAY_PICK_CLAMP_MS=500
# PRODUCTION_MOVE_POSITION_MM=320
# PRODUCTION_MOVE_SPEED_MM_S=80
# PRODUCTION_SKIP_PICK_PLACE=1
# PRODUCTION_SKIP_CENTRING=1
# PRODUCTION_QUEUE_MAX_DEPTH=8
# CENTRING_INTER_PHASE_SETTLE_MS=0

# Skip motion homing during DI0 initialization (bench without Nano hardware)
# PICK_PLACE_SKIP_INIT=1
# CENTRING_SKIP_INIT=1

# ── Centring controller (Nano ENC28J60 on machine LAN) ───────────────────────
# CENTRING_HOST=192.168.10.55
# CENTRING_PORT=8177
# CENTRING_GAP_MOVE_SPEED_DEG_S=90
# Legacy JSON path — used only for one-time migration into SQLite (system_settings.centring_config)
# CENTRING_CONFIG_PATH=/path/to/centring_config.json

# ── Vision Pi proxy (US Machine = Ethernet master) ─────────────────────────────
# Base URL of the vision slave (default: http://192.168.10.2:5000). /api suffix is stripped.
VISION_URL=http://192.168.10.2:5000
# VISION_SLAVE_URL=http://192.168.10.2:5000/api   # alias for CLI / tooling

# Remote key — master → slave (/api/remote/*). Matches vision Pi VISION_REMOTE_API_KEY.
# VISION_REMOTE_KEY=your-remote-secret-here
# VISION_REMOTE_API_KEY=your-remote-secret-here   # alias

# Local key — only if the slave locks /api/programs and this HMI proxies program CRUD.
# Master run-once does NOT need this. Do not confuse with VISION_REMOTE_KEY.
# VISION_LOCAL_KEY=your-local-secret-here
# VISION_LOCAL_API_KEY=your-local-secret-here     # alias

# ── Pick & Place controller (Nano ENC28J60 on machine LAN eth0) ───────────────
# Nano TCP slave (master = this Pi on 192.168.10.1)
# PICK_PLACE_HOST=192.168.10.5
# PICK_PLACE_PORT=8177
# PICK_PLACE_CONNECT_TIMEOUT_MS=10000
# PICK_PLACE_SINGLE_MOTOR=0
# Skip HOMEA/HOMEB during machine init (bench without Nano)
# PICK_PLACE_SKIP_INIT=1
# Legacy JSON path — used only for one-time migration into SQLite (system_settings.pick_place_config)
# PICK_PLACE_CONFIG_PATH=/path/to/pick_place_config.json

# ── Reference broadcast (USB serial, e.g. FTDI FT232) ─────────────────────────
# After a valid scan/select, the API sends the canonical DB name to both paths.
# REFERENCE_SERIAL_WELD_PATH=/dev/ttyUSB0
# REFERENCE_SERIAL_SHRINK_PATH=/dev/ttyUSB1
# Shared defaults (used when per-port vars below are unset):
# REFERENCE_SERIAL_BAUD=9600
# REFERENCE_SERIAL_LINE_ENDING=CRLF
# Optional per machine (override shared baud / line ending for that port only):
# REFERENCE_SERIAL_WELD_BAUD=9600
# REFERENCE_SERIAL_SHRINK_BAUD=9600
# REFERENCE_SERIAL_WELD_LINE_ENDING=CRLF
# REFERENCE_SERIAL_SHRINK_LINE_ENDING=CRLF
