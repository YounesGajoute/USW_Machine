# ── SQL database (SQLite maindata.db) API ───────────────────────────────────
# Production builds use `.env.production` → http://127.0.0.1:3333 (see `npm run build`).
# `scripts/launch-display-hdmi.sh` starts that API automatically before Chromium.
#
# Install server deps once:  npm install --prefix server
#
# Dev — same-origin /api via Vite proxy (run API + UI: npm run dev:full):
#   VITE_SETTINGS_API=true
#
# Dev — or point the SPA at the API URL:
#   VITE_API_BASE_URL=http://127.0.0.1:3333
#
# Dev — pure browser storage (no SQL): leave the above unset.
#
# Built-in kiosk accounts (names, passwords, active, hidden from customer UI):
#   config/default-users.json
#   Typical split: `admin` = operational ADMIN; `vendor` = BYPASS (System / break-glass).

# VITE_SETTINGS_API=true
# VITE_API_BASE_URL=http://127.0.0.1:3333

# Optional — in dev, hide settings sidebar pages the same way as production (General → toggles):
# VITE_PREVIEW_PRODUCTION_SETTINGS_SIDEBAR=true

# ── Vision Inspection System ─────────────────────────────────────────────────
# IP address and port of the Vision Pi (Flask + Socket.IO backend).
# Default fallback: http://192.168.1.100:5000
VITE_VISION_URL=http://192.168.10.2:5000

# Default inspection program ID to use on startup (program must exist on the Vision Pi).
# Program 2 = "Heat-Shrink Tube Inspection" (2 tools: Tube Presence + Tube Alignment)
VITE_VISION_PROGRAM_ID=2

# Remote key only (X-Vision-Remote-Key + Socket.IO auth.remoteKey) — matches slave remote.api_key.
# Set when the vision Pi requires require_remote_api_key. Do NOT use the local API key here.
# WARNING: visible in the browser bundle — trusted LAN only.
# VITE_VISION_REMOTE_KEY=your-remote-secret-here

# Program list uses the HMI proxy (/api/vision/programs); local key belongs in backend/.env if needed.
